<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.sky.xposed.rimet">

    <!-- Required on Android 11+ so getPackageInfo can see DingTalk -->
    <queries>
        <package android:name="com.alibaba.android.rimet" />
    </queries>

    <application
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        android:allowBackup="false"
        android:extractNativeLibs="false">

        <!-- Settings / launcher Activity — required for LSPosed to list this module -->
        <activity
            android:name=".ui.activity.MainActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="de.robv.android.xposed.category.MODULE_SETTINGS" />
            </intent-filter>
        </activity>

        <!-- Required for LSPosed Manager to recognise this APK as an Xposed module -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <meta-data
            android:name="xposeddescription"
            android:value="DingTalk Hook Helper" />

        <!--
             xposedminversion >= 100 signals to LSPosed that this module uses the
             modern libxposed API (io.github.libxposed:api:101.0.0).
             No assets/xposed_init is needed; LSPosed reads xposedmoduleentry instead.
        -->
        <meta-data
            android:name="xposedminversion"
            android:value="101" />

        <!-- Hook scope: only inject into DingTalk -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

        <!--
             Entry point for the libxposed modern API.
             Replaces the legacy assets/xposed_init plain-text file.
        -->
        <meta-data
            android:name="xposedmoduleentry"
            android:value="com.sky.xposed.rimet.Main" />

        <!--
             XposedProvider: ContentProvider that the libxposed framework uses to deliver
             its binder into the hooked process. Required on Android 11+ / LSPosed so that
             the hook code can call XposedService.getRemotePreferences() to read module
             SharedPreferences without relying on createPackageContext (which is blocked by
             SELinux in sandboxed environments).
        -->
        <provider
            android:name="io.github.libxposed.service.XposedProvider"
            android:authorities="${applicationId}"
            android:exported="true"
            android:multiprocess="false" />

    </application>

</manifest>
